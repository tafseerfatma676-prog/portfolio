# ─── MongoDB ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.mongodb.net/portfolio?retryWrites=true&w=majority

# ─── NextAuth ──────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_super_secret_random_string_here
